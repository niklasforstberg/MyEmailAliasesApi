# Caddyfile configuration for email.forstberg.net
# This file should be placed in your Caddy configuration directory
# (typically /etc/caddy/Caddyfile or wherever your Caddy instance reads its config)

email.forstberg.net {
    # Reverse proxy to the Docker container
    # The API container exposes port 8080 on localhost (or whatever port you set in API_PORT)
    # Change 8080 to match the API_PORT value in your .env file if different
    reverse_proxy localhost:8080 {
        # Preserve original request information
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        
        # Health check
        health_uri /health
        health_interval 30s
        health_timeout 5s
    }
    
    # Cloudflare Tunnel handles TLS, so Caddy doesn't need to manage certificates
    # If you're using Caddy's automatic HTTPS, uncomment the line below:
    # tls {
    #     # Caddy will automatically obtain and renew certificates
    # }
    
    # Logging (optional)
    log {
        output file /var/log/caddy/email.forstberg.net.log
        format json
    }
    
    # Compression
    encode gzip zstd
}
