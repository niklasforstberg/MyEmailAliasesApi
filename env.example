# Database Configuration
# Point to your existing production database Docker container
#
# Option 1: If database container exposes port 1433 on localhost (most common):
#   Find your database container: docker ps | grep sql
#   Check if it maps port: docker ps | grep <container-name>
#   Use: Server=host.docker.internal (Docker Desktop) or Server=<host-ip> (Linux)
DB_CONNECTION_STRING=Server=host.docker.internal;Database=EmailAliasesDb;User Id=sa;Password=YourSecurePasswordHere;TrustServerCertificate=True;Encrypt=False
#
# Option 2: If database container is on a Docker network (recommended):
#   1. Find database network: docker inspect <db-container> | grep NetworkMode
#   2. Add network to docker-compose.yml (uncomment networks section)
#   3. Use container name as server: Server=<db-container-name>
#   Example: DB_CONNECTION_STRING=Server=my-sql-server;Database=EmailAliasesDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True;Encrypt=False
#
# Option 3: If database uses host network mode:
#   Use: Server=localhost or Server=127.0.0.1
#   Example: DB_CONNECTION_STRING=Server=localhost;Database=EmailAliasesDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True;Encrypt=False

# JWT Configuration
JWT_KEY=YourSuperSecretJWTKeyHere_MakeItLongAndRandom

# API Port Configuration
# Change this if port 8080 is already in use by another application
# Make sure to update your Caddyfile to match this port
API_PORT=8080

# Note: JWT Issuer and Audience are set in docker-compose.yml to https://email.forstberg.net
# ALLOWED_ORIGINS is also set in docker-compose.yml
